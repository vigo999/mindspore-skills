{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindspore-skills.dev/schema/performance-verdict-0.1.json",
  "title": "Performance Agent Verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill",
    "status",
    "summary",
    "working_dir",
    "trace_root",
    "evidence_level",
    "available_artifacts",
    "ranked_bottlenecks",
    "next_action",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "performance-agent/0.1"
    },
    "skill": {
      "type": "string",
      "const": "performance-agent"
    },
    "status": {
      "type": "string",
      "enum": [
        "TRACE_REQUIRED",
        "PROFILE_RECOVERED",
        "BOTTLENECK_IDENTIFIED",
        "VALIDATION_PENDING",
        "VALIDATED_IMPROVEMENT"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "working_dir": {
      "type": ["string", "null"]
    },
    "trace_root": {
      "type": ["string", "null"]
    },
    "stack": {
      "type": ["string", "null"]
    },
    "workload_type": {
      "type": ["string", "null"]
    },
    "metric_focus": {
      "type": ["string", "null"]
    },
    "primary_symptom": {
      "type": ["string", "null"]
    },
    "evidence_level": {
      "type": ["string", "null"]
    },
    "available_artifacts": {
      "type": "object"
    },
    "dominant_bottleneck": {
      "$ref": "#/$defs/candidate"
    },
    "ranked_bottlenecks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "validation_result": {
      "type": ["object", "null"]
    },
    "recommended_action": {
      "type": ["string", "null"]
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "object"
    }
  },
  "$defs": {
    "candidate": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "name",
        "confidence",
        "evidence",
        "validation_checks",
        "optimization_hints"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optimization_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
