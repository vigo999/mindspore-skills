{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindspore-skills.dev/schema/report-1.0.0.json",
  "title": "MindSpore Skills Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill",
    "run_id",
    "status",
    "start_time",
    "end_time",
    "duration_sec",
    "steps",
    "logs",
    "artifacts",
    "env_ref",
    "inputs_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "skill": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failed", "partial"]
    },
    "start_time": {
      "type": "string",
      "format": "date-time"
    },
    "end_time": {
      "type": "string",
      "format": "date-time"
    },
    "duration_sec": {
      "type": "number",
      "minimum": 0
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outRelativePath"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outRelativePath"
      }
    },
    "env_ref": {
      "type": "string",
      "const": "meta/env.json"
    },
    "inputs_ref": {
      "type": "string",
      "const": "meta/inputs.json"
    },
    "error": {
      "$ref": "#/$defs/error"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["error"]
      }
    }
  ],
  "$defs": {
    "outRelativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!\\.\\./).+"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "partial", "skipped"]
        },
        "duration_sec": {
          "type": "number",
          "minimum": 0
        },
        "message": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": ["E_ENV", "E_BUILD", "E_VERIFY", "E_INTERNAL"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
