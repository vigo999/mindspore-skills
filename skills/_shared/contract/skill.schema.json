{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindspore-skills.dev/schema/skill-1.0.0.json",
  "title": "MindSpore Skill Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "display_name",
    "description",
    "entry",
    "inputs",
    "outputs",
    "permissions",
    "dependencies"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["python", "shell", "manual"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inputField"
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_schema", "out_dir_layout"],
      "properties": {
        "report_schema": {
          "type": "string",
          "const": "skills/_shared/contract/report.schema.json"
        },
        "out_dir_layout": {
          "type": "string",
          "const": "runs/<run_id>/out/"
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "filesystem"],
      "properties": {
        "network": {
          "type": "string",
          "enum": ["none", "required", "optional"]
        },
        "filesystem": {
          "type": "string",
          "enum": ["read", "write", "workspace-write"]
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools"],
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "python": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "inputField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "path", "enum"]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "default": {},
        "choices": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
